# DeepSeek API key (all text generation) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Groq API key (vision/image analysis) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Lemon Squeezy webhook secret — https://app.lemonsqueezy.com/settings/webhooks
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# Lemon Squeezy product IDs (for webhook plan detection)
LEMON_SQUEEZY_PRODUCT_PRO=your_pro_product_id_here
LEMON_SQUEEZY_PRODUCT_PROMAX=your_promax_product_id_here

# Resend API key for sending token emails — https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Admin panel password (set your own)
ADMIN_PASSWORD=your_admin_password_here

# From email for Resend (must be verified domain in Resend)
FROM_EMAIL=noreply@contact.morelikecreator.com
