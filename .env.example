# Gemini API key (free tier) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Apify API key for YouTube transcript extraction — https://console.apify.com/account/integrations
APIFY_API_KEY=your_apify_api_key_here

# Resend API key for sending token emails — https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Admin panel password (set your own)
ADMIN_PASSWORD=your_admin_password_here

# From email for Resend (must be verified domain in Resend)
FROM_EMAIL=noreply@contact.morelikecreator.com
